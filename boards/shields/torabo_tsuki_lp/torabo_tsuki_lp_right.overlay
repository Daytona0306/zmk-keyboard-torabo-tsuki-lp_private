#include "torabo_tsuki_lp.dtsi"
#include <input/processors.dtsi>
#include <dt-bindings/zmk/input_transform.h>
#include <behaviors/input_gestures_accel.dtsi> 
#include <scroll-snap.dtsi>

&trackball_listener {
    input-processors = 
        <&zip_xy_transform (INPUT_TRANSFORM_X_INVERT | INPUT_TRANSFORM_Y_INVERT)>,  // base transform
        <&zip_xy_scaler 2 1>;  // X/Yを2倍スケール（CPI上げ相当）

    scroller {
        layers = <4>;  //有効化するレイヤーの指定
        input-processors = 
            <&pointer_accel>,  // 加速追加
            // <&zip_xy_transform INPUT_TRANSFORM_XY_SWAP>,     //X軸とY軸の入れ替え
            // <&zip_xy_transform INPUT_TRANSFORM_X_INVERT>,       //X軸反転
            <&zip_xy_to_scroll_mapper>,                         //スクロールモードに変更
            <&zip_scroll_snap>,
            <&zip_scroll_transform INPUT_TRANSFORM_X_INVERT>,   //スクロールのX軸反転
            <&zip_scroll_scaler 1 30>;                           //スクロール量を1/30倍
    };
};

&size_s_transform {
    col-offset = <7>;
};

// &size_m_transform {
//     col-offset = <7>;
// };

&size_l_transform {
    col-offset = <7>;
};

&pointer_accel {  // 参照形式でオーバーライド
    input-type = <INPUT_EV_REL>;  // 相対入力用
    codes = <INPUT_REL_X INPUT_REL_Y>;  // XY入力対象（スクロール変換前に適用）

    // プリセット使用時はこれでOK。カスタム例（Level 1、スクロール向け調整）:
    sensitivity = <1>;     // ベース感度0.001x
    max-factor = <5000>;      // 最大加速5.0x
    curve-type = <1>;         // 曲線タイプ: 0=Linear, 1=Mild, 2=Strong
    // y-boost = <1300>;         // Y軸ブースト1.3x（縦スクロール強調）
   sensor-dpi = <400>;       // センサーDPI（trackball調整）
};
