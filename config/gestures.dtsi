/* トラックボールジェスチャー補正版 (レイヤー5: 矢印キー専用) */
#include <dt-bindings/zmk/input_transform.h>
#include <mouse-gesture.dtsi>

/ {
    /* 方向補正用の定義：90度回転の設定 */
    /* compatible を zmk,input-processor-transform に修正することで binding エラーを解消します */
    gesture_fix_transform: gesture_fix_transform {
        compatible = "zmk,input-processor-transform";
        #input-processor-cells = <1>;
    };

    layer_listeners {
        compatible = "zmk,layer-listeners";
        gesture_on_l5 {
            layers = <5>;
            bindings = <&mouse_gesture_on &mouse_gesture_off>;
        };
    };

    gesture_l5_proc: gesture_l5_proc {
        compatible = "zmk,input-processor-mouse-gesture";
        #input-processor-cells = <0>;
        enable-eager-mode;
        stroke-size = <10>; 
        movement-threshold = <5>;
        idle-timeout-ms = <100>;
        gesture-cooldown-ms = <100>;

        up    { pattern = <GESTURE_UP>;    bindings = <&kp UP>;    };
        down  { pattern = <GESTURE_DOWN>;  bindings = <&kp DOWN>;  };
        left  { pattern = <GESTURE_LEFT>;  bindings = <&kp LEFT>;  };
        right { pattern = <GESTURE_RIGHT>; bindings = <&kp RIGHT>; };
    };
};

&trackball_listener {
    gest_on_l5 {
        layers = <5>;
        /* * 1. 6 (XY_SWAP | Y_INVERT) で 90度回転補正
         * 2. ジェスチャー判定
         * 3. 最後にカーソル移動を殺す 
         */
        input-processors = <
            &gesture_fix_transform 6
            &gesture_l5_proc 
            &zip_xy_scaler 0 1
        >;
    };
};
