/* トラックボールジェスチャー定義 (レイヤー5: 矢印キー専用) */

#define GESTURE_UP 0
#define GESTURE_DOWN 1
#define GESTURE_LEFT 2
#define GESTURE_RIGHT 3

/ {
    /* --- 1. レヤー5に入った時だけジェスチャー機能をONにする --- */
    layer_listeners {
        compatible = "zmk,layer-listeners";

        gesture_on_l5 {
            layers = <5>;
            bindings = <&mouse_gesture_on &mouse_gesture_off>;
        };
    };

    /* --- 2. ジェスチャー動作の定義 (矢印キー) --- */
    gesture_l5_proc: gesture_l5_proc {
        compatible = "zmk,input-processor-mouse-gesture";
        #input-processor-cells = <0>;
        enable-eager-mode;
        stroke-size = <10>; 
        movement-threshold = <6>;
        idle-timeout-ms = <100>;
        gesture-cooldown-ms = <100>;

        up    { pattern = <GESTURE_UP>;    bindings = <&kp UP>;    };
        down  { pattern = <GESTURE_DOWN>;  bindings = <&kp DOWN>;  };
        left  { pattern = <GESTURE_LEFT>;  bindings = <&kp LEFT>;  };
        right { pattern = <GESTURE_RIGHT>; bindings = <&kp RIGHT>; };
    };
};

/* --- 3. 基板側のリスナーにレイヤー5の設定を紐付ける --- */
&trackball_listener {
    /* レイヤー5の時だけジェスチャーを実行し、同時にカーソル移動を止める */
    gest_on_l5 {
        layers = <5>;
        input-processors = <&gesture_l5_proc &zip_xy_scaler 0 1>;
    };
};
