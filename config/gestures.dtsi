/* トラックボールジェスチャー定義 */
#define GESTURE_UP 0
#define GESTURE_DOWN 1
#define GESTURE_LEFT 2
#define GESTURE_RIGHT 3

/ {
    /* レイヤーごとの振り分け設定 (Listener Group) */
    trackball_gesture_routing {
        compatible = "zmk,input-listener-group";
        device = <&trackball>;

        /* 1. レイヤー5：矢印ジェスチャー */
        route_l5 {
            layers = <5>;
            input-processors = <&gesture_arrows_proc>;
        };

        /* 2. レイヤー7：タブ操作ジェスチャー */
        route_l7 {
            layers = <7>;
            input-processors = <&gesture_l7_proc>;
        };

        /* 3. 重要：それ以外のすべてのレイヤーでの通常移動 */
        route_cursor {
            /* 指定のないレイヤーでは通常のカーソル移動として処理する */
            input-processors = <&zip_temp_config_scaler>;
        };
    };

    /* ジェスチャー動作の定義 (Processor) */
    gesture_l7_proc: gesture_l7_proc {
        compatible = "zmk,input-processor-mouse-gesture";
        #input-processor-cells = <0>;
        enable-eager-mode;
        stroke-size = <5>;
        movement-threshold = <6>;
        idle-timeout-ms = <100>;
        gesture-cooldown-ms = <120>;

        prev_tab    { pattern = <GESTURE_LEFT>;  bindings = <&kp LC(LS(TAB))>; };
        next_tab    { pattern = <GESTURE_RIGHT>; bindings = <&kp LC(TAB)>;     };
        Create_tab  { pattern = <GESTURE_UP>;    bindings = <&kp LC(T)>;       };
        close_tab   { pattern = <GESTURE_DOWN>;  bindings = <&kp LC(W)>;       };
    };

    gesture_arrows_proc: gesture_arrows_proc {
        compatible = "zmk,input-processor-mouse-gesture";
        #input-processor-cells = <0>;
        enable-eager-mode;
        stroke-size = <10>; 
        movement-threshold = <6>;
        idle-timeout-ms = <100>;
        gesture-cooldown-ms = <100>;
        up    { pattern = <GESTURE_UP>;    bindings = <&kp UP>;    };
        down  { pattern = <GESTURE_DOWN>;  bindings = <&kp DOWN>;  };
        left  { pattern = <GESTURE_LEFT>;  bindings = <&kp LEFT>;  };
        right { pattern = <GESTURE_RIGHT>; bindings = <&kp RIGHT>; };
    };
};

/* 基板側の標準リスナーを無効化（上記の routing に一本化するため） */
&trackball_listener {
    status = "disabled";
};
