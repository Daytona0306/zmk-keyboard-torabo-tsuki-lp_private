/* 実装できていたコードをベースにした【完全版】 */
#include <input/processors.dtsi>
#include <dt-bindings/zmk/input_transform.h>
#include <mouse-gesture.dtsi>

/* mouse-gesture.h で定義されているので、ここの #define は削除して衝突を防ぎます */

/ {
    layer_listeners {
        compatible = "zmk,layer-listeners";
        gesture_on_l5 {
            layers = <5>;
            bindings = <&mouse_gesture_on &mouse_gesture_off>;
        };
    };

    gesture_l5_proc: gesture_l5_proc {
        compatible = "zmk,input-processor-mouse-gesture";
        #input-processor-cells = <0>;
        enable-eager-mode;
        /* 感度を少し上げて、左右も反応しやすくします */
        stroke-size = <8>; 
        movement-threshold = <4>;
        idle-timeout-ms = <100>;
        gesture-cooldown-ms = <100>;

        up    { pattern = <GESTURE_UP>;    bindings = <&kp UP>;    };
        down  { pattern = <GESTURE_DOWN>;  bindings = <&kp DOWN>;  };
        left  { pattern = <GESTURE_LEFT>;  bindings = <&kp LEFT>;  };
        right { pattern = <GESTURE_RIGHT>; bindings = <&kp RIGHT>; };
    };
};

&trackball_listener {
    gest_on_l5 {
        layers = <5>;
        input-processors = <
            &zip_xy_transform INPUT_TRANSFORM_X_INVERT
            &zip_xy_transform INPUT_TRANSFORM_Y_INVERT
            &gesture_l5_proc 
            &zip_xy_scaler 0 1
        >;
    };
};
